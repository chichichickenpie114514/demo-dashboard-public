# ── AppSheet ─────────────────────────────────────────────────────────
APPSHEET_APP_ID=your-appsheet-app-uuid
# APPSHEET_API_KEY=  (set only if using live AppSheet data)

# ── Google Sheets (haifu) ────────────────────────────────────────────
HAIFU_SHEET_ID=your-google-sheet-id

# ── GCP Deploy ───────────────────────────────────────────────────────
GCP_PROJECT=your-gcp-project-id
GCP_PROJECT_NUMBER=your-gcp-project-number

# ── Required for OAuth ──────────────────────────────────────────────
# Create OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Set redirect URI to: http://localhost:5000/auth/callback (local) or your Cloud Run URL
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ── Flask session ───────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-string

# ── AI Analysis (optional) ──────────────────────────────────────────
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_MODEL=deepseek-v4-flash

# ── Google Maps ───────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ── Admin access (optional) ─────────────────────────────────────────
# Comma-separated emails allowed to trigger snapshot refresh
ADMIN_EMAILS=your-email@gmail.com

# ── GCS (optional) ──────────────────────────────────────────────────
# Set to a GCS bucket name to load data from GCS instead of local data/
# GCS_BUCKET=your-bucket-name
